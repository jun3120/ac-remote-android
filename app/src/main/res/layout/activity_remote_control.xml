<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- 品牌标题 -->
        <TextView
            android:id="@+id/tv_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="空调遥控器"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 温度显示 -->
        <TextView
            android:id="@+id/tv_temperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24°C"
            android:textSize="56sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            app:layout_constraintTop_toBottomOf="@id/tv_brand"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- 模式显示 -->
        <TextView
            android:id="@+id/tv_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动"
            android:textSize="16sp"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintTop_toBottomOf="@id/tv_temperature"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />

        <!-- 温度调节 -->
        <LinearLayout
            android:id="@+id/layout_temp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_mode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_temp_down"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="−"
                android:textSize="28sp"
                app:cornerRadius="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="温度"
                android:textSize="14sp"
                android:layout_marginHorizontal="16dp" />

            <Button
                android:id="@+id/btn_temp_up"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="+"
                android:textSize="28sp"
                app:cornerRadius="32dp" />
        </LinearLayout>

        <!-- 模式选择 -->
        <TextView
            android:id="@+id/tv_mode_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="模式"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintTop_toBottomOf="@id/layout_temp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/layout_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_mode_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <Button android:id="@+id/btn_cool" style="@style/RemoteButton" android:text="制冷" />
            <Button android:id="@+id/btn_heat" style="@style/RemoteButton" android:text="制热" />
            <Button android:id="@+id/btn_auto" style="@style/RemoteButton" android:text="自动" />
            <Button android:id="@+id/btn_fan" style="@style/RemoteButton" android:text="送风" />
            <Button android:id="@+id/btn_dry" style="@style/RemoteButton" android:text="除湿" />
        </LinearLayout>

        <!-- 风速选择 -->
        <TextView
            android:id="@+id/tv_speed_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="风速"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintTop_toBottomOf="@id/layout_mode"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:id="@+id/layout_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_speed_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <Button android:id="@+id/btn_speed_auto" style="@style/RemoteButton" android:text="自动" />
            <Button android:id="@+id/btn_speed_low" style="@style/RemoteButton" android:text="低" />
            <Button android:id="@+id/btn_speed_mid" style="@style/RemoteButton" android:text="中" />
            <Button android:id="@+id/btn_speed_high" style="@style/RemoteButton" android:text="高" />
        </LinearLayout>

        <!-- 开关 + 扫风 -->
        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/layout_speed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="28dp">

            <Button
                android:id="@+id/btn_power"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="开机"
                android:textSize="18sp"
                style="@style/Widget.Material3.Button" />

            <Button
                android:id="@+id/btn_swing"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="扫风"
                android:textSize="18sp"
                android:layout_marginStart="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
