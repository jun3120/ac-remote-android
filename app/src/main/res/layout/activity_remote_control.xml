<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="20dp">

    <!-- 品牌名 -->
    <TextView
        android:id="@+id/tv_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="空调遥控器"
        android:textSize="15sp"
        android:textColor="#8888AA"
        android:layout_marginTop="12dp"
        android:layout_gravity="center_horizontal" />

    <!-- 温度显示 -->
    <TextView
        android:id="@+id/tv_temperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="24°C"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"
        android:layout_gravity="center_horizontal" />

    <!-- 模式 + 风速 标签 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="制冷"
            android:textSize="15sp"
            android:textColor="#8A8AFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textSize="15sp"
            android:textColor="#555577" />

        <TextView
            android:id="@+id/tv_fan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动风速"
            android:textSize="15sp"
            android:textColor="#8A8AFF" />
    </LinearLayout>

    <!-- 温度加减 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="28dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_temp_down"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="−"
            android:textSize="36sp"
            android:textColor="#CCCCFF"
            app:cornerRadius="40dp"
            app:backgroundTint="#2A2A4E"
            app:strokeColor="#4444AA"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="32dp"
            android:minWidth="100dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="温度调节"
                android:textSize="14sp"
                android:textColor="#8888AA" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_temp_up"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="+"
            android:textSize="36sp"
            android:textColor="#CCCCFF"
            app:cornerRadius="40dp"
            app:backgroundTint="#2A2A4E"
            app:strokeColor="#4444AA"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <!-- 功能按钮区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="28dp">

        <!-- 模式切换 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mode"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="切换模式 ▶"
            android:textSize="16sp"
            android:textColor="#CCCCFF"
            app:cornerRadius="14dp"
            app:backgroundTint="#2A2A4E"
            app:strokeColor="#4444AA"
            app:strokeWidth="1dp"
            app:icon="@android:drawable/ic_menu_sort_alphabetically"
            app:iconGravity="textStart"
            app:iconTint="#8888FF" />

        <!-- 风速切换 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_fan_speed"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="切换风速 ▶"
            android:textSize="16sp"
            android:textColor="#CCCCFF"
            app:cornerRadius="14dp"
            app:backgroundTint="#2A2A4E"
            app:strokeColor="#4444AA"
            app:strokeWidth="1dp"
            android:layout_marginTop="12dp"
            app:icon="@android:drawable/ic_menu_sort_alphabetically"
            app:iconGravity="textStart"
            app:iconTint="#8888FF" />

        <!-- 扫风 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_swing"
            android:layout_width="280dp"
            android:layout_height="56dp"
            android:text="扫风：关"
            android:textSize="16sp"
            android:textColor="#CCCCFF"
            app:cornerRadius="14dp"
            app:backgroundTint="#2A2A4E"
            app:strokeColor="#4444AA"
            app:strokeWidth="1dp"
            android:layout_marginTop="12dp" />

        <!-- 开关 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_power"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:text="⏻  开  机"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:backgroundTint="#4444CC"
            android:layout_marginTop="20dp" />
    </LinearLayout>

</LinearLayout>
